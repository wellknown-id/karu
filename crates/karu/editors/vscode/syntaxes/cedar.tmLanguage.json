{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PolicySet",
  "scopeName": "source.cedar",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#identifiers"
    },
    {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.block.paren.cedar",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.block.paren.cedar",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\[",
      "end": "\\]",
      "name": "meta.block.bracket.cedar",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.block.brace.cedar",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.block.paren.cedar",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "match": "\\b(?:permit|forbid|principal|action|resource|in|when|unless|has|like|if|then|else|context|true|false)\\b",
          "name": "keyword.control.cedar"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "\\(|\\)|;|@|,|==|\\[|\\]|::|\\{|\\}|\\|\\||&&|\\+|-|\\*|!|\\.|!=|<|<=|>|>=|:",
          "name": "keyword.operator.cedar"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "-?[0-9]+",
          "name": "constant.numeric.cedar"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"([^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.cedar"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "variable.other.cedar"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(::[a-zA-Z_][a-zA-Z0-9_]*)*",
          "name": "variable.other.cedar"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*|\"([^\"\\\\]|\\\\.)*\"",
          "name": "variable.other.cedar"
        }
      ]
    }
  }
}