{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Program",
  "scopeName": "source.karu",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#identifiers"
    },
    {
      "begin": "<",
      "end": ">",
      "name": "meta.block.angle.karu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.block.paren.karu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\[",
      "end": "\\]",
      "name": "meta.block.bracket.karu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.block.brace.karu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.karu"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(?:import|use|schema|mod|actor|resource|in|is|abstract|action|appliesTo|context|Set|assert|test|true|false|expect|if|allow|deny|or|and|not|forall|exists|has|null|_)\\b",
          "name": "keyword.control.karu"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": ";|\\{|\\}|,|\\||\\?|<|>|:|\\(|\\)|==|!=|<=|>=|\\.|\\[|\\]",
          "name": "keyword.operator.karu"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?",
          "name": "constant.numeric.karu"
        },
        {
          "match": "\\d+",
          "name": "constant.numeric.karu"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"([^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.karu"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "variable.other.karu"
        }
      ]
    }
  }
}