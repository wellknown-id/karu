{
    // See https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Karu Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/crates/karu/editors/vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/crates/karu/editors/vscode/**/*.js"
            ],
            "preLaunchTask": "Build Extension + LSP"
        }
    ]
}
